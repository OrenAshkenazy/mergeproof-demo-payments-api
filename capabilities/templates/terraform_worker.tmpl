resource "kubernetes_deployment" "${worker_name}" {
  metadata {
    name = "${service}-${worker_name}"
    labels = {
      app       = "${service}"
      component = "${worker_name}"
    }
  }

  spec {
    replicas = 1

    selector {
      match_labels = {
        app       = "${service}"
        component = "${worker_name}"
      }
    }

    template {
      metadata {
        labels = {
          app       = "${service}"
          component = "${worker_name}"
        }
      }

      spec {
        container {
          name    = "${worker_name}"
          image   = "${service}:latest"
          command = ["python", "-m", "app.workers.${worker_name}"]

          # Runtime env from the service-level aggregate ConfigMap + ExternalSecret
          # (managed by MergeProof's aggregate_env_wiring); names are static.
          env_from {
            config_map_ref {
              name = "${service}-runtime-config"
            }
          }

          env_from {
            secret_ref {
              name = "${service}-runtime-secrets"
            }
          }
        }
      }
    }
  }
}
